{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "daily-report-preview",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('os').tmpdir()+'/pps-daily-preview.html';h.createServer((q,r)=>{r.writeHead(200,{'Content-Type':'text/html'});r.end(fs.readFileSync(p))}).listen(4321,()=>console.log('ready'))"],
      "port": 4321
    }
  ]
}
